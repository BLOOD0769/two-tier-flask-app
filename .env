# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored, so your real secrets never get pushed to GitHub.

# Root password for the MySQL server itself
MYSQL_ROOT_PASSWORD=changeme_root_password

# The database that will be created automatically on first startup
MYSQL_DATABASE=guestbook

# A regular (non-root) MySQL user that the Flask app will use to connect
MYSQL_USER=app_user
MYSQL_PASSWORD=changeme_app_password
